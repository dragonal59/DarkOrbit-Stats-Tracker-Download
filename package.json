{
  "name": "do-stats-tracker",
  "version": "2.5.9",
  "description": "DO Stats Tracker",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/dragonal59/DarkOrbit-Stats-Tracker-Download.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "prebuild": "node scripts/generate-grades-inline.js && node scripts/obfuscate-build.js && node scripts/inject-supabase-config.js",
    "build": "electron-builder"
  },
  "author": {
    "name": "dragonal59",
    "email": "bnoisiez@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "javascript-obfuscator": "^4.1.1"
  },
  "build": {
    "appId": "com.dostats.tracker",
    "productName": "DO Stats Tracker",
    "artifactName": "DOStatsTracker-Setup-v${version}.exe",
    "publish": {
      "provider": "github",
      "owner": "dragonal59",
      "repo": "DarkOrbit-Stats-Tracker-Download",
      "releaseType": "release",
      "vPrefixedTagName": true
    },
    "win": {
      "target": "nsis",
      "icon": "src/img/icon_app/icon_app.ico"
    },
    "linux": {
      "icon": "src/img/icon_app/icon_app.png"
    },
    "mac": {
      "icon": "src/img/icon_app/icon_app.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "fr"
      ],
      "language": "1036",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DO Stats Tracker",
      "installerIcon": "src/img/icon_app/icon_app.ico",
      "uninstallerIcon": "src/img/icon_app/icon_app.ico"
    },
    "files": [
      "main.js",
      "changelog.json",
      {
        "from": "electron",
        "to": "electron"
      },
      {
        "from": "build/src",
        "to": "src"
      },
      "!**/*.map",
      "!src/**",
      "!scripts/**",
      "!supabase/**",
      "!*.md",
      "!.env",
      "!.gitignore"
    ],
    "asar": true,
    "asarUnpack": [
      "src/img/**",
      "changelog.json"
    ]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "chrome-remote-interface": "^0.33.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.4",
    "electron-updater": "^6.8.3"
  }
}