SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
# Sans .env : vous pouvez placer un fichier config.supabase.local.js à la racine (module.exports { url, anonKey, ... }) pour npm run dev sans dossier build/
# Clé service_role (secrète) : utilisée par le scraper Python pour envoyer les données HoF vers Supabase (contourne RLS). Ne pas commiter.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=your_project_id
AUTH_REDIRECT_BASE=https://dragonal59.github.io/darkorbit-tracker-auth/
# UUID Supabase du compte SuperAdmin — utilisé en fallback si global.currentUserId est absent
SUPERADMIN_USER_ID=

# PayPal Subscriptions — optionnel si vous utilisez les valeurs par défaut du plan PRO dans paypal-buttons.js
PAYPAL_CLIENT_ID=
PAYPAL_PLAN_ID=
