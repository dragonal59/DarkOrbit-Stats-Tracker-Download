{
  "manifest_version": 3,
  "name": "DarkOrbit Stats Scraper",
  "version": "1.0.0",
  "description": "Scrape automatiquement les classements DarkOrbit (23 serveurs)",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://*.darkorbit.com/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.darkorbit.com/*"],
      "js": ["utils.js", "config.js", "grade-mappings.js", "scraper.js", "events-scraper.js", "content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["blank.html","blank.js","start-scraping-bridge.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
